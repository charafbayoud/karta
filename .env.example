# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google (Phase 4+)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_ROUTES_API_KEY=
GOOGLE_ROADS_API_KEY=

# Enable "Maps Static API" in Google Cloud for share preview map captures

# Strava (Phase 5+)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=

# Resend
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=KARTA <hello@karta.club>

# App — use localhost for local V2 dev, karta.club in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local dev mode — uses built-in routes + .data/waitlist.json
# KARTA_USE_LOCAL_DATA=true

# Local QA — skip login on outdoor/indoor/dashboard (development only)
# KARTA_DEV_BYPASS_AUTH=true
